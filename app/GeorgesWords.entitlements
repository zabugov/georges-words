<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime (required for notarization) blocks the mic
         unless this is granted. Used only by the release workflow's
         Developer ID signing; local build.sh signing is unaffected. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
